APP_NAME=PTW Backend
APP_ENV=dev

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ptw

# JSON array (Pydantic v2 expects this)
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:4000","http://localhost:4001"]
CORS_ORIGINS=[
  "http://localhost:5173",
  "http://localhost:8081",
  "http://54.252.159.4:4000",
  "http://54.252.159.4:4001"
]

# JWT
SECRET_KEY=super-secret-dev-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Push (optional; leave blank until you have a Firebase SA)
FCM_PROJECT_ID=
FCM_SA_EMAIL=
FCM_SA_PRIVATE_KEY=
